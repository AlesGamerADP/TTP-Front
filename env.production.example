# Configuración de PRODUCCIÓN del frontend.
# No subas valores reales a Git.
#
# Opción A — Vercel (recomendado):
#   Vercel → Project → Settings → Environment Variables (Production + Preview)
#   Pega cada variable (Production + Preview si aplica).
#
# Opción B — Probar build de producción en local:
#   cp env.production.example .env.production.local
#   Edita las URLs, luego: npm run build && npm start
#
# Stack: Vercel (front) + Render (back) + Neon + Cloudinary

# --- Recomendado: proxy same-origin (Safari, iOS, WhatsApp) ---
# El navegador llama a https://tu-app.vercel.app/api/... y Vercel reenvía a Render.
# Las cookies de sesión quedan en el dominio del front (primera parte).
NEXT_PUBLIC_API_PROXY=true
NEXT_PUBLIC_API_URL=

# URL del backend para SSR y reenvío del proxy (servidor Next / Vercel)
INTERNAL_API_URL=https://ttp-back.onrender.com

# URL pública del frontend (SEO, sitemap, metadata)
NEXT_PUBLIC_SITE_URL=https://tu-app.vercel.app

# Opcional. Ya no se guarda el usuario en localStorage; solo hace falta si migras datos legacy.
# NEXT_PUBLIC_ENCRYPTION_KEY=

# --- Modo legacy (no recomendado en móvil) ---
# Cookies cross-site; Safari/WhatsApp suelen bloquearlas.
# NEXT_PUBLIC_API_PROXY=false
# NEXT_PUBLIC_API_URL=https://ttp-back.onrender.com
# INTERNAL_API_URL=https://ttp-back.onrender.com
