# Copia a .env.local (no se sube a Git):
#   cp env.example .env.local
#
# Stack: Vercel (front) + Render (back) + Neon + Cloudinary

# --- Desarrollo local ---
# Arranca el backend en el puerto 4000 antes de npm run dev (si no: ERR_CONNECTION_REFUSED en /api/users/me).
# NO actives USE_SAME_ORIGIN_API en local: el front llama directo al :4000 y evita ERR_CONTENT_DECODING_FAILED.
NEXT_PUBLIC_API_URL=http://localhost:4000
INTERNAL_API_URL=http://localhost:4000
NEXT_PUBLIC_ENCRYPTION_KEY=dev-local-encryption-key-32chars-min
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_USE_SAME_ORIGIN_API=true   ← solo Vercel, no en .env.local de desarrollo

# --- Producción Vercel (configurar en Vercel Dashboard → Environment Variables) ---
# Safari móvil bloquea cookies httpOnly en peticiones cross-site (front → Render).
# Usa API por el mismo dominio del front:
# NEXT_PUBLIC_USE_SAME_ORIGIN_API=true
# NEXT_PUBLIC_API_URL=/
# INTERNAL_API_URL=https://ingetec-back.onrender.com
# NEXT_PUBLIC_SITE_URL=https://tu-app.vercel.app
# NEXT_PUBLIC_ENCRYPTION_KEY=genera-con-openssl-rand-hex-32-distinto-del-backend
#
# Seguridad / navegadores:
# - Sesión real: cookies httpOnly (authToken / refreshToken) del backend.
# - localStorage: solo caché de perfil (nombre, rol); no guarda contraseñas.
# - Safari privado / WhatsApp in-app: pueden bloquear localStorage o cookies;
#   abrir en Safari/Chrome y usar NEXT_PUBLIC_USE_SAME_ORIGIN_API=true en Vercel.
