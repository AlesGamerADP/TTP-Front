# Plantilla de DESARROLLO LOCAL (no se sube a Git).
#   cp env.example .env.local
#
# Plantilla de PRODUCCIÓN: ver env.production.example
#   cp env.production.example .env.production.local
#   o configurar en Vercel → Environment Variables
#
# Stack: Vercel (front) + Render (back) + Neon + Cloudinary

# --- Desarrollo local ---
# Proxy same-origin → http://localhost:3000/api/* reenvía al backend (recomendado)
NEXT_PUBLIC_API_PROXY=true
NEXT_PUBLIC_API_URL=
INTERNAL_API_URL=http://localhost:4000

# Alternativa: API directa sin proxy (comportamiento legacy)
# NEXT_PUBLIC_API_PROXY=false
# NEXT_PUBLIC_API_URL=http://localhost:4000
# INTERNAL_API_URL=http://localhost:4000

NEXT_PUBLIC_SITE_URL=http://localhost:3000
